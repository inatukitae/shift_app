<h2>シフト作成</h2>

<%= form_with url: new_sim_path, method: :get, local: true do |f| %>
  <div style="margin-bottom: 20px;">
    <%= f.label :start_date, "開始日:" %>
    <%= f.date_field :start_date, value: Date.today, style: "margin-right: 20px;" %>

    <%= f.label :end_date, "終了日:" %>
    <%= f.date_field :end_date, value: 30.days.since.to_date %>
    
    <%= f.submit "シフト作成へ進む", style: "margin-left: 20px; padding: 5px 15px;" %>
  </div>
<% end %>

<hr>
