<h2 style="border-bottom: 2px solid #333; padding-bottom: 10px;">必要人数設定</h2>

<div style="display: flex; gap: 20px; align-items: start; width: 100%; margin-top: 20px;">

  <%# ==================== 左カラム：薬剤師 ==================== %>
  <div style="flex: 1; min-width: 0; padding: 20px; border: 2px solid #e6f2ff; border-radius: 10px; background: #fff;">
    <h2 style="background: #e6f2ff; color: #0056b3; padding: 10px; border-radius: 5px; margin-top: 0; font-size: 1.3em; text-align: center;">
      【薬剤師】必要人数設定
    </h2>

    <% (0..6).each do |wday| %>
      <% wday_name = ["日", "月", "火", "水", "木", "金", "土"][wday] %>
      <h3 style="border-left: 4px solid #0056b3; padding-left: 8px; margin-top: 25px; margin-bottom: 10px; color: #333;"><%= wday_name %>曜日</h3>
      
      <table border="1" style="border-collapse: collapse; width: 100%; text-align: center; font-size: 0.85em; border-color: #eee;">
        <thead>
          <tr style="background: #f8f9fa; color: #555;">
            <th style="padding: 6px;">時間帯</th>
            <th style="padding: 6px;">必要人数</th>
            <th style="padding: 6px;">操作</th>
          </tr>
        </thead>
        <tbody>
          <% if @required_staff_settings.present? && @required_staff_settings[wday].present? %>
            <%# job_typeカラムが存在する場合は「薬剤師」で絞り込み、ない場合は全表示 %>
            <% pharmacist_data = @required_staff_settings[wday].select { |s| s.respond_to?(:job_type) ? s.job_type == "薬剤師" : true } %>
            
            <% if pharmacist_data.any? %>
              <% pharmacist_data.each do |setting| %>
                <tr>
                  <td style="padding: 8px; font-weight: bold; color: #0056b3;">
                    <%= "#{setting.start_time&.strftime('%H:%M')} ～ #{setting.end_time&.strftime('%H:%M')}" rescue "08:45 ～ 19:00" %>
                  </td>
                  <td style="padding: 8px;"><%= setting.required_count rescue "1" %>人</td>
                  <td style="padding: 8px;">
                    <%= link_to "編集", edit_required_staff_setting_path(setting), style: "color: #0056b3; text-decoration: none;" rescue "編集" %> |
                    <%= link_to "削除", setting, method: :delete, data: { confirm: "削除しますか？" }, style: "color: #d32f2f; text-decoration: none;" rescue "削除" %>
                  </td>
                </tr>
              <% end %>
            <% else %>
              <tr><td colspan="3" style="padding: 15px; color: #999; background: #fafafa;">設定されたシフト枠はありません</td></tr>
            <% end %>
          <% else %>
            <tr><td colspan="3" style="padding: 15px; color: #999; background: #fafafa;">設定されたシフト枠はありません</td></tr>
          <% end %>
        </tbody>
      </table>

      <%# --- 薬剤師用：新規追加フォーム --- %>
      <div style="margin-top: 10px; padding: 12px; background: #f8f9fa; border-radius: 6px; border: 1px solid #eef0f2; font-size: 0.85em;">
        <%= form_with(model: RequiredStaffSetting.new, local: true) do |f| %>
          <%= f.hidden_field :day_of_week, value: wday %>
          <%= f.hidden_field :job_type, value: "薬剤師" %>
          
          <span style="font-weight: bold; margin-right: 5px;"><%= wday_name %>曜日に枠を追加:</span>
          <%= f.time_field :start_time, style: "padding: 4px; border: 1px solid #ccc; border-radius: 4px;" %> ～
          <%= f.time_field :end_time, style: "padding: 4px; border: 1px solid #ccc; border-radius: 4px;" %>
          <%= f.number_field :required_count, placeholder: "人数", style: "width: 50px; padding: 4px; border: 1px solid #ccc; border-radius: 4px; text-align: center;" %>
          <%= f.submit "追加", style: "background: #e6f2ff; color: #0056b3; border: 1px solid #b3d7ff; padding: 4px 12px; border-radius: 4px; font-weight: bold; cursor: pointer;" %>
        <% end %>
      </div>
    <% end %>
  </div>

  <%# ==================== 右カラム：事務員 ==================== %>
  <div style="flex: 1; min-width: 0; padding: 20px; border: 2px solid #fff2e6; border-radius: 10px; background: #fff;">
    <h2 style="background: #fff2e6; color: #d97706; padding: 10px; border-radius: 5px; margin-top: 0; font-size: 1.3em; text-align: center;">
      【事務員】必要人数設定
    </h2>

    <% (0..6).each do |wday| %>
      <% wday_name = ["日", "月", "火", "水", "木", "金", "土"][wday] %>
      <h3 style="border-left: 4px solid #d97706; padding-left: 8px; margin-top: 25px; margin-bottom: 10px; color: #333;"><%= wday_name %>曜日</h3>
      
      <table border="1" style="border-collapse: collapse; width: 100%; text-align: center; font-size: 0.85em; border-color: #eee;">
        <thead>
          <tr style="background: #f8f9fa; color: #555;">
            <th style="padding: 6px;">時間帯</th>
            <th style="padding: 6px;">必要人数</th>
            <th style="padding: 6px;">操作</th>
          </tr>
        </thead>
        <tbody>
          <% if @required_staff_settings.present? && @required_staff_settings[wday].present? %>
            <%# データベースにjob_typeカラムがある前提で事務員を抽出 %>
            <% clerk_data = @required_staff_settings[wday].select { |s| s.respond_to?(:job_type) ? s.job_type == "事務員" : false } %>
            
            <% if clerk_data.any? %>
              <% clerk_data.each do |setting| %>
                <tr>
                  <td style="padding: 8px; font-weight: bold; color: #d97706;">
                    <%= "#{setting.start_time&.strftime('%H:%M')} ～ #{setting.end_time&.strftime('%H:%M')}" rescue "09:30 ～ 19:30" %>
                  </td>
                  <td style="padding: 8px;"><%= setting.required_count rescue "1" %>人</td>
                  <td style="padding: 8px;">
                    <%= link_to "編集", edit_required_staff_setting_path(setting), style: "color: #0056b3; text-decoration: none;" rescue "編集" %> |
                    <%= link_to "削除", setting, method: :delete, data: { confirm: "削除しますか？" }, style: "color: #d32f2f; text-decoration: none;" rescue "削除" %>
                  </td>
                </tr>
              <% end %>
            <% else %>
              <tr><td colspan="3" style="padding: 15px; color: #999; background: #fafafa;">設定されたシフト枠はありません</td></tr>
            <% end %>
          <% else %>
            <tr><td colspan="3" style="padding: 15px; color: #999; background: #fafafa;">設定されたシフト枠はありません</td></tr>
          <% end %>
        </tbody>
      </table>

      <%# --- 事務員用：新規追加フォーム --- %>
      <div style="margin-top: 10px; padding: 12px; background: #f8f9fa; border-radius: 6px; border: 1px solid #eef0f2; font-size: 0.85em;">
        <%= form_with(model: RequiredStaffSetting.new, local: true) do |f| %>
          <%= f.hidden_field :day_of_week, value: wday %>
          <%= f.hidden_field :job_type, value: "事務員" %>
          
          <span style="font-weight: bold; margin-right: 5px;"><%= wday_name %>曜日に枠を追加:</span>
          <%= f.time_field :start_time, style: "padding: 4px; border: 1px solid #ccc; border-radius: 4px;" %> ～
          <%= f.time_field :end_time, style: "padding: 4px; border: 1px solid #ccc; border-radius: 4px;" %>
          <%= f.number_field :required_count, placeholder: "人数", style: "width: 50px; padding: 4px; border: 1px solid #ccc; border-radius: 4px; text-align: center;" %>
          <%= f.submit "追加", style: "background: #fff2e6; color: #d97706; border: 1px solid #ffd8b3; padding: 4px 12px; border-radius: 4px; font-weight: bold; cursor: pointer;" %>
        <% end %>
      </div>
    <% end %>
  </div>

</div>